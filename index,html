                            </div>
                        </div>
                    </footer>
                </div>
            `;

            app.innerHTML = htmlContent;
        };

        // ==============================================================================
        // 5. EVENT HANDLERS (Untuk Memperbarui State & Memicu Re-Render)
        // ==============================================================================
        window.setTab = (tabName) => {
            state.activeTab = tabName;
            state.currentPage = 1; // Reset pagination
            updateApp();
        };

        window.handleKChange = (val) => {
            state.kValue = parseInt(val);
            updateApp();
        };

        window.handleTrainRatioChange = (val) => {
            state.trainRatio = parseInt(val);
            updateApp();
        };

        window.toggleScaling = () => {
            state.useScaling = !state.useScaling;
            updateApp();
        };

        window.handlePatientInput = (field, val) => {
            state.inputPasien[field] = parseInt(val);
            updateApp();
        };

        window.changePage = (direction) => {
            const totalPages = Math.ceil(state.dataset.length / state.itemsPerPage);
            const targetPage = state.currentPage + direction;
            if (targetPage >= 1 && targetPage <= totalPages) {
                state.currentPage = targetPage;
                updateApp();
            }
        };

        // INSIALISASI PERTAMA KALI
        window.onload = () => {
            state.dataset = generateDataset();
            updateApp();
        };
    </script>
</body>
</html>
