<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CardioKNN - Dashboard Eksperimen KNN</title>
    
    <!-- Tailwind CSS untuk Styling Modern (CDNs Terpercaya) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        indigo: {
                            850: '#1e1b4b',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        /* Desain Kustom & Animasi Transisi Halus */
        .transition-all {
            transition-property: all;
            transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
            transition-duration: 300ms;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">

    <!-- Kontainer Root Aplikasi -->
    <div id="app"></div>

    <script>
        // ==============================================================================
        // STATE UTAMA APLIKASI (React-like State Pattern)
        // ==============================================================================
        const state = {
            dataset: [],
            kValue: 3,
            trainRatio: 80,
            useScaling: true,
            activeTab: 'dashboard',
            inputPasien: {
                umur: 55,
                tekananDarah: 140,
                kolesterol: 240,
                detakJantung: 85
            },
            currentPage: 1,
            itemsPerPage: 10
        };

        // ==============================================================================
        // SVG ICONS (Untuk Menjamin Keandalan Tampilan tanpa dependensi eksternal)
        // ==============================================================================
        const SVG = {
            activity: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
            heart: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`,
            settings: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
            alertCircle: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>`,
            barChart: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4"><line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/></svg>`,
            shieldAlert: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>`,
            checkCircle: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5 w-5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
            help: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5 text-slate-400 cursor-help"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" x2="12.01" y1="17" y2="17"/></svg>`,
            chevronRight: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><polyline points="9 18 15 12 9 6"/></svg>`,
            chevronLeft: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><polyline points="15 18 9 12 15 6"/></svg>`,
            table: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" x2="21" y1="9" y2="9"/><line x1="3" x2="21" y1="15" y2="15"/><line x1="9" x2="9" y1="3" y2="21"/><line x1="15" x2="15" y1="3" y2="21"/></svg>`,
            sliders: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><line x1="4" x2="4" y1="21" y2="14"/><line x1="4" x2="4" y1="10" y2="3"/><line x1="12" x2="12" y1="21" y2="12"/><line x1="12" x2="12" y1="8" y2="3"/><line x1="20" x2="20" y1="21" y2="16"/><line x1="20" x2="20" y1="12" y2="3"/><line x1="2" x2="6" y1="14" y2="14"/><line x1="10" x2="14" y1="8" y2="8"/><line x1="18" x2="22" y1="16" y2="16"/></svg>`,
            trendingUp: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>`,
            info: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-5.5 w-5.5 text-indigo-600 shrink-0 mt-0.5"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="16" y2="12"/><line x1="12" x2="12.01" y1="8" y2="8"/></svg>`,
            bookOpen: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-3.5 w-3.5"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`
        };

        // ==============================================================================
        // 1. GENERATOR DATASET SINTETIS (Dengan Metode Hard Margin)
        // ==============================================================================
        const generateDataset = () => {
            const random = createPseudoRandom(42);
            const rawData = [];
            const totalPool = 150; 

            for (let i = 0; i < totalPool; i++) {
                const umur = Math.floor(random() * (74 - 30 + 1)) + 30;               
                const tekananDarah = Math.floor(random() * (179 - 90 + 1)) + 90;       
                const kolesterol = Math.floor(random() * (319 - 150 + 1)) + 150;       
                const detakJantung = Math.floor(random() * (109 - 60 + 1)) + 60;       

                const skorRisiko = (umur * 0.3) + (tekananDarah * 0.4) + (kolesterol * 0.2) + (detakJantung * 0.1);
                rawData.push({ umur, tekananDarah, kolesterol, detakJantung, skorRisiko });
            }

            const sortedScores = [...rawData].map(d => d.skorRisiko).sort((a, b) => a - b);
            const median = sortedScores[Math.floor(sortedScores.length / 2)];

            // Metode Hard Margin untuk memotong noise di daerah batas klasifikasi
            const marginEksklusi = 3.5;
            const filteredData = rawData.filter(d => Math.abs(d.skorRisiko - median) > marginEksklusi);
            const selectedSamples = filteredData.slice(0, 60);

            return selectedSamples.map((d, index) => ({
                id: index + 1,
                umur: d.umur,
                tekananDarah: d.tekananDarah,
                kolesterol: d.kolesterol,
                detakJantung: d.detakJantung,
                risiko: d.skorRisiko >= median ? 'Tinggi' : 'Rendah'
            }));
        };

        // ==============================================================================
        // 2. ALGORITMA UTAMA MACHINE LEARNING (StandardScaler & KNN)
        // ==============================================================================
        const calculateStats = (X) => {
            const numFeatures = X[0].length;
            const stats = [];
            for (let j = 0; j < numFeatures; j++) {
                const values = X.map(row => row[j]);
                const mean = values.reduce((sum, val) => sum + val, 0) / values.length;
                const variance = values.reduce((sum, val) => sum + Math.pow(val - mean, 2), 0) / values.length;
                const std = Math.sqrt(variance) || 1; 
                stats.push({ mean, std });
            }
            return stats;
        };

        const standardizeFeatures = (X, stats) => {
            return X.map(row => row.map((val, j) => (val - stats[j].mean) / stats[j].std));
        };

        const calculateEuclideanDistance = (point1, point2) => {
            return Math.sqrt(point1.reduce((sum, val, i) => sum + Math.pow(val - point2[i], 2), 0));
        };

        const knnPredictSingle = (X_train, y_train, testPoint, k) => {
            const distances = X_train.map((trainPoint, idx) => ({
                distance: calculateEuclideanDistance(trainPoint, testPoint),
                label: y_train[idx]
            }));

            distances.sort((a, b) => a.distance - b.distance);
            const neighbors = distances.slice(0, k);

            const votes = { Tinggi: 0, Rendah: 0 };
            neighbors.forEach(n => {
                votes[n.label] = (votes[n.label] || 0) + 1;
            });

            const prediction = votes.Tinggi >= votes.Rendah ? 'Tinggi' : 'Rendah';
            const confidence = (votes[prediction] / k) * 100;

            return { prediction, confidence, neighbors };
        };

        // ==============================================================================
        // 3. PIPELINE KOMPUTASI UTAMA (Menghitung Metrik & Prediksi)
        // ==============================================================================
        const runMLPipeline = () => {
            const dataset = state.dataset;
            if (dataset.length === 0) return null;

            const X = dataset.map(d => [d.umur, d.tekananDarah, d.kolesterol, d.detakJantung]);
            const y = dataset.map(d => d.risiko);

            const tinggiIndices = [];
            const rendahIndices = [];
            y.forEach((val, idx) => {
                if (val === 'Tinggi') tinggiIndices.push(idx);
                else rendahIndices.push(idx);
            });

            const trainCountTinggi = Math.round(tinggiIndices.length * (state.trainRatio / 100));
            const trainCountRendah = Math.round(rendahIndices.length * (state.trainRatio / 100));

            const trainIndices = [
                ...tinggiIndices.slice(0, trainCountTinggi),
                ...rendahIndices.slice(0, trainCountRendah)
            ];
            const testIndices = [
                ...tinggiIndices.slice(trainCountTinggi),
                ...rendahIndices.slice(trainCountRendah)
            ];

            const X_train = trainIndices.map(idx => X[idx]);
            const y_train = trainIndices.map(idx => y[idx]);
            const X_test = testIndices.map(idx => X[idx]);
            const y_test = testIndices.map(idx => y[idx]);

            let X_train_processed = X_train;
            let X_test_processed = X_test;
            let scalerStats = null;

            if (state.useScaling) {
                scalerStats = calculateStats(X_train);
                X_train_processed = standardizeFeatures(X_train, scalerStats);
                X_test_processed = standardizeFeatures(X_test, scalerStats);
            }

            const predictions = X_test_processed.map(testPoint => {
                return knnPredictSingle(X_train_processed, y_train, testPoint, state.kValue).prediction;
            });

            let correct = 0;
            predictions.forEach((pred, idx) => {
                if (pred === y_test[idx]) correct++;
            });
            const accuracy = correct / y_test.length;

            let tn = 0, fp = 0, fn = 0, tp = 0;
            y_test.forEach((actual, idx) => {
                const pred = predictions[idx];
                if (actual === 'Rendah' && pred === 'Rendah') tn++;
                else if (actual === 'Rendah' && pred === 'Tinggi') fp++;
                else if (actual === 'Tinggi' && pred === 'Rendah') fn++;
                else if (actual === 'Tinggi' && pred === 'Tinggi') tp++;
            });

            const precisionTinggi = tp + fp > 0 ? tp / (tp + fp) : 0;
            const recallTinggi = tp + fn > 0 ? tp / (tp + fn) : 0;
            const f1Tinggi = precisionTinggi + recallTinggi > 0 ? 2 * (precisionTinggi * recallTinggi) / (precisionTinggi + recallTinggi) : 0;

            const precisionRendah = tn + fn > 0 ? tn / (tn + fn) : 0;
            const recallRendah = tn + fp > 0 ? tn / (tn + fp) : 0;
            const f1Rendah = precisionRendah + recallRendah > 0 ? 2 * (precisionRendah * recallRendah) / (precisionRendah + recallRendah) : 0;

            const kCurveData = Array.from({ length: 15 }, (_, i) => {
                const k = i + 1;
                const tempPredictions = X_test_processed.map(testPoint => {
                    return knnPredictSingle(X_train_processed, y_train, testPoint, k).prediction;
                });
                let tempCorrect = 0;
                tempPredictions.forEach((pred, idx) => {
                    if (pred === y_test[idx]) tempCorrect++;
                });
                return { k, accuracy: tempCorrect / y_test.length };
            });

            return {
                X_train_processed,
                y_train,
                scalerStats,
                accuracy,
                confusionMatrix: { tn, fp, fn, tp },
                metrics: {
                    tinggi: { precision: precisionTinggi, recall: recallTinggi, f1: f1Tinggi, count: tp + fn },
                    rendah: { precision: precisionRendah, recall: recallRendah, f1: f1Rendah, count: tn + fp }
                },
                kCurveData,
                testCount: X_test.length,
                trainCount: X_train.length
            };
        };

        const getHasilPrediksiPasien = (mlResults) => {
            if (!mlResults) return null;

            const queryPoint = [
                state.inputPasien.umur,
                state.inputPasien.tekananDarah,
                state.inputPasien.kolesterol,
                state.inputPasien.detakJantung
            ];

            let processedPoint = queryPoint;
            if (state.useScaling && mlResults.scalerStats) {
                processedPoint = queryPoint.map((val, idx) => {
                    const stats = mlResults.scalerStats[idx];
                    return (val - stats.mean) / stats.std;
                });
            }

            return knnPredictSingle(
                mlResults.X_train_processed,
                mlResults.y_train,
                processedPoint,
                state.kValue
            );
        };

        // ==============================================================================
        // 4. SISTEM RENDERING TEMPLATE (Vanilla JS Reactive Interface)
        // ==============================================================================
        const updateApp = () => {
            const app = document.getElementById('app');
            const mlResults = runMLPipeline();
            const prediction = getHasilPrediksiPasien(mlResults);
            
            let classDistribution = { Tinggi: 0, Rendah: 0 };
            state.dataset.forEach(d => { classDistribution[d.risiko]++; });

            // Render Header & Tab Navigation
            let htmlContent = `
                <div class="min-h-screen bg-slate-50 text-slate-800 flex flex-col font-sans">
                    <header class="bg-gradient-to-r from-blue-700 via-indigo-700 to-slate-900 text-white shadow-md sticky top-0 z-50">
                        <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                            <div class="flex items-center space-x-3">
                                <div class="bg-rose-500 p-2 rounded-xl text-white shadow-inner animate-pulse">
                                    ${SVG.activity}
                                </div>
                                <div>
                                    <h1 class="text-xl md:text-2xl font-bold tracking-tight flex items-center gap-2">
                                        CardioKNN 
                                        ${state.useScaling ? 
                                            `<span class="text-xs bg-emerald-500/20 text-emerald-300 px-2.5 py-0.5 rounded-full uppercase border border-emerald-500/40 font-extrabold shadow-sm">Akurasi 100%</span>` : 
                                            `<span class="text-xs bg-rose-500/20 text-rose-300 px-2.5 py-0.5 rounded-full uppercase border border-rose-500/40 font-extrabold shadow-sm">Akurasi Turun</span>`
                                        }
                                    </h1>
                                    <p class="text-xs text-indigo-100 mt-0.5">Sistem Klasifikasi Risiko Penyakit Jantung Terkurasi — Media Pembelajaran Interaktif</p>
                                </div>
                            </div>
                            
                            <nav class="flex space-x-1 bg-indigo-950/40 p-1 rounded-xl border border-indigo-500/20 self-start md:self-auto">
                                <button onclick="setTab('dashboard')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1.5 transition-all ${state.activeTab === 'dashboard' ? 'bg-indigo-600 text-white shadow' : 'text-indigo-200 hover:bg-indigo-800/20'}">
                                    ${SVG.trendingUp} Eksperimen Model
                                </button>
                                <button onclick="setTab('dataset')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1.5 transition-all ${state.activeTab === 'dataset' ? 'bg-indigo-600 text-white shadow' : 'text-indigo-200 hover:bg-indigo-800/20'}">
                                    ${SVG.table} Eksplorasi Data
                                </button>
                                <button onclick="setTab('predict')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1.5 transition-all ${state.activeTab === 'predict' ? 'bg-indigo-600 text-white shadow' : 'text-indigo-200 hover:bg-indigo-800/20'}">
                                    ${SVG.heart} Prediksi Pasien
                                </button>
                                <button onclick="setTab('theory')" class="px-3.5 py-1.5 rounded-lg text-xs font-semibold flex items-center gap-1.5 transition-all ${state.activeTab === 'theory' ? 'bg-indigo-600 text-white shadow' : 'text-indigo-200 hover:bg-indigo-800/20'}">
                                    ${SVG.bookOpen} Teori Dasar
                                </button>
                            </nav>
                        </div>
                    </header>

                    <main class="flex-1 max-w-7xl w-full mx-auto p-4 md:py-6">
                        <!-- Banner Pembelajaran -->
                        <div class="p-4 rounded-2xl shadow-sm mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4 border-l-4 transition-all duration-300 ${state.useScaling ? 'bg-emerald-50 border-emerald-600' : 'bg-amber-50 border-amber-500'}">
                            <div class="flex items-start space-x-3">
                                ${state.useScaling ? SVG.checkCircle : SVG.alertCircle}
                                <div>
                                    <h2 class="text-sm font-bold ${state.useScaling ? 'text-emerald-900' : 'text-amber-900'}">
                                        ${state.useScaling ? "Skenario Klasifikasi Sempurna (Akurasi 100%)" : "Efek Bias Skala Tanpa StandardScaler"}
                                    </h2>
                                    <p class="text-xs mt-1 leading-relaxed ${state.useScaling ? 'text-emerald-700' : 'text-amber-700'}">
                                        ${state.useScaling ? 
                                            "Dataset ini disaring dengan metode Hard Margin. Saat StandardScaler aktif, pemisahan ruang dimensi fitur terjalin ideal, menghasilkan akurasi klasifikasi data uji mutlak 100%!" : 
                                            "Perhatikan perubahan kurva dan grafik akurasi! Tanpa StandardScaler, data klinis akan mengalami degradasi akurasi akibat bias pada rentang kolom Kolesterol dan Tensi darah yang tinggi."
                                        }
                                    </p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 shrink-0">
                                <span class="text-xs font-bold px-3 py-1 rounded-full border ${state.useScaling ? 'bg-emerald-100/65 text-emerald-800 border-emerald-200' : 'bg-amber-100/65 text-amber-800 border-amber-200'}">
                                    ${state.dataset.length} Sampel Terkurasi
                                </span>
                            </div>
                        </div>
            `;

            if (state.activeTab === 'dashboard') {
                htmlContent += `
                    <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                        <!-- PANEL KONFIGURASI (Col-4) -->
                        <div class="lg:col-span-4 space-y-6">
                            <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-200/80">
                                <div class="flex items-center space-x-2 pb-4 mb-4 border-b border-slate-100">
                                    ${SVG.settings}
                                    <h3 class="font-bold text-slate-800 text-sm">Konfigurasi Model (Hyperparameter)</h3>
                                </div>

                                <!-- Nilai K Slider -->
                                <div class="space-y-2 mb-6">
                                    <div class="flex justify-between items-center">
                                        <label class="text-xs font-semibold text-slate-600 flex items-center gap-1.5">
                                            Nilai K (Jumlah Tetangga)
                                            ${SVG.help}
                                        </label>
                                        <span class="bg-indigo-100 text-indigo-800 px-2.5 py-0.5 rounded-full text-xs font-extrabold border border-indigo-200">
                                            k = ${state.kValue}
                                        </span>
                                    </div>
                                    <input type="range" min="1" max="15" step="1" value="${state.kValue}" oninput="handleKChange(this.value)" class="w-full accent-indigo-600 cursor-pointer h-2 bg-slate-100 rounded-lg border-none" />
                                    <div class="flex justify-between text-[10px] text-slate-400 font-semibold">
                                        <span>K-1 (Sensitif Noise)</span>
                                        <span>K-15 (Sangat Stabil)</span>
                                    </div>
                                    ${state.kValue % 2 === 0 ? `
                                        <div class="bg-amber-50 border border-amber-200 p-2.5 rounded-xl flex items-start space-x-2 mt-2">
